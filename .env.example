# ─── SnapVision Environment Configuration ─────────────────────
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Only DEEPSEEK_API_KEY is truly optional — the app works with
# local PaddleOCR even without it.

# ─── API Keys ─────────────────────────────────────────────────

# DeepSeek API Key — enables AI-enhanced stock screenshot analysis
# Get one at: https://platform.deepseek.com/api_keys
# When unset, the app falls back to local PaddleOCR + rule-based parsing
# DEEPSEEK_API_KEY=sk-your-key-here

# ─── OCR Server ───────────────────────────────────────────────

# Port for the local OCR Flask server (default: 5002)
# OCR_PORT=5002

# Host address for the OCR server (default: 127.0.0.1)
# HOST=127.0.0.1

# ─── Python ────────────────────────────────────────────────────

# Path to Python 3 binary (auto-detected if unset)
# PYTHON_BIN=/opt/homebrew/bin/python3
