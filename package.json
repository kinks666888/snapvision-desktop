{
  "name": "snapvision-desktop",
  "version": "0.1.0",
  "description": "SnapVision Desktop — OCR screenshot analysis for macOS",
  "private": true,
  "main": "dist-electron/main.js",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:mac": "bash scripts/bundle-python.sh && vite build && electron-builder --mac",
    "dist": "bash scripts/bundle-python.sh && vite build && electron-builder",
    "dist:mac": "bash scripts/bundle-python.sh && vite build && electron-builder --mac",
    "dist:win": "vite build && electron-builder --win",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "lightweight-charts": "^5.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^6.4.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.6"
  },
  "build": {
    "appId": "com.snapvision.desktop",
    "productName": "SnapVision",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*.py",
          "!**/test_*.py",
          "!**/*_test.py"
        ]
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  }
}
